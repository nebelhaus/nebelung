{
  "document":    { "block_prefix": "\n", "block_suffix": "\n", "color": "#d7d7d7", "margin": 2 },
  "block_quote": { "color": "#aeaeae", "italic": true, "indent": 1, "indent_token": "│ " },
  "paragraph":   {},
  "list":        { "level_indent": 2 },
  "heading":     { "block_suffix": "\n", "color": "#d7d7d7", "bold": true },
  "h1": { "prefix": " ", "suffix": " ", "color": "#202020", "background_color": "#c9a8f1", "bold": true },
  "h2": { "prefix": "## ",     "color": "#c9a8f1",    "bold": true },
  "h3": { "prefix": "### ",    "color": "#b5bff8", "bold": true },
  "h4": { "prefix": "#### ",   "color": "#8db4f3",     "bold": true },
  "h5": { "prefix": "##### ",  "color": "#7dc6e7", "bold": true },
  "h6": { "prefix": "###### ", "color": "#aeaeae", "bold": true },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph":   { "color": "#efcece", "italic": true },
  "strong": { "bold": true },
  "hr": { "color": "#717171", "format": "\n────────\n" },
  "item":        { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". " },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link":       { "color": "#8db4f3",     "underline": true },
  "link_text":  { "color": "#b5bff8", "bold": true },
  "image":      { "color": "#8db4f3",     "underline": true },
  "image_text": { "color": "#858585", "format": "Image: {{.text}} →" },
  "code": { "prefix": " ", "suffix": " ", "color": "#f5b58e", "background_color": "#343434" },
  "code_block": {
    "color": "#aeaeae",
    "margin": 2,
    "chroma": {
      "text":            { "color": "#d7d7d7" },
      "error":           { "color": "#d7d7d7", "background_color": "#ed8fa9" },
      "comment":         { "color": "#717171", "italic": true },
      "comment_preproc": { "color": "#8db4f3" },
      "keyword":           { "color": "#c9a8f1" },
      "keyword_reserved":  { "color": "#c9a8f1" },
      "keyword_namespace": { "color": "#f7e2b5" },
      "keyword_type":      { "color": "#f7e2b5" },
      "operator":    { "color": "#91dbe8" },
      "punctuation": { "color": "#9a9a9a" },
      "name":           { "color": "#d7d7d7" },
      "name_builtin":   { "color": "#f5b58e" },
      "name_tag":       { "color": "#c9a8f1" },
      "name_attribute": { "color": "#f7e2b5" },
      "name_class":     { "color": "#f7e2b5", "bold": true },
      "name_constant":  { "color": "#f5b58e" },
      "name_decorator": { "color": "#f2c4e5" },
      "name_exception": { "color": "#ed8fa9" },
      "name_function":  { "color": "#8db4f3" },
      "name_other":     { "color": "#d7d7d7" },
      "literal":               { "color": "#f5b58e" },
      "literal_number":        { "color": "#f5b58e" },
      "literal_date":          { "color": "#f5b58e" },
      "literal_string":        { "color": "#abe1a6" },
      "literal_string_escape": { "color": "#f2c4e5" },
      "generic_deleted":    { "color": "#ed8fa9" },
      "generic_emph":       { "italic": true },
      "generic_inserted":   { "color": "#abe1a6" },
      "generic_strong":     { "bold": true },
      "generic_subheading": { "color": "#91dbe8" },
      "background":         { "background_color": "#191919" }
    }
  },
  "table": { "center_separator": "┼", "column_separator": "│", "row_separator": "─" },
  "definition_list": {},
  "definition_term": { "bold": true },
  "definition_description": { "block_prefix": "\n🠶 " },
  "html_block": {},
  "html_span": {}
}
